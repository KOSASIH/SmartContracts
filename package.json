{
  "name": "kosasih-smartcontracts-shielded",
  "version": "2.0.0",
  "description": "SmartContracts with Global Symbol Shield Protection + Pi Network Integration",
  "main": "src/shield-backend.js",
  "scripts": {
    "start": "node src/shield-backend.js",
    "dev": "nodemon src/shield-backend.js",
    "shield": "node src/shield-backend.js",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js --network localhost",
    "test": "npm run test:backend && npm run test:contracts",
    "test:backend": "jest",
    "test:contracts": "npx hardhat test",
    "react:dev": "vite",
    "build": "vite build"
  },
  "dependencies": {
    "@pi-network/sdk": "^1.0.0",
    "ethers": "^6.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "hardhat": "^2.19.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0"
  },
  "keywords": [
    "smart-contracts",
    "pi-network",
    "symbol-shield",
    "web3-protection",
    "blockchain-security"
  ],
