# ========================================
# SmartContracts Shield - PRODUCTION .env
# ========================================

# 🔑 EVM Wallets
PRIVATE_KEY=your_real_private_key_here
TAX_WALLET=0x742d35Cc6634C0532925a3b8D7c7aB471A8207a3

# 📍 Contract Addresses
RPI_ADDRESS=0xYourRealRPIAddress
DEX_ADDRESS=0xYourRealDEXAddress

# 🔍 API Keys
BSCSCAN_API_KEY=YourBscScanAPIKey
INFURA_API_KEY=your_infura_key
ETHERSCAN_API_KEY=your_etherscan_key

# 🌐 Pi Network
PI_APP_ID=your_pi_app_id
PI_API_KEY=your_pi_api_key
MERCHANT_ID=your_merchant_id

# 🌉 Networks
RPC_BSC=https://bsc-dataseed1.binance.org/
RPC_ETH=https://mainnet.infura.io/v3/${INFURA_API_KEY}
RPC_PI=your_pi_rpc

# ⚙️ Config
PORT=3001
TAX_RATE=2
MAX_TX_AMOUNT=1000000
MIN_TX_AMOUNT=1
